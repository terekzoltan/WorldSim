{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://worldsim.local/refinery-service-java/schema/patch-response-v1.schema.json",
  "title": "PatchResponse v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "requestId",
    "seed",
    "patch",
    "explain",
    "warnings"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v1"
    },
    "requestId": {
      "type": "string",
      "minLength": 1
    },
    "seed": {
      "type": "integer"
    },
    "patch": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op",
              "opId",
              "techId",
              "prereqTechIds",
              "cost",
              "effects"
            ],
            "properties": {
              "op": {
                "const": "addTech"
              },
              "opId": {
                "type": "string",
                "minLength": 1
              },
              "techId": {
                "type": "string",
                "minLength": 1
              },
              "prereqTechIds": {
                "type": "array",
                "items": {
                  "type": "string"
                }
              },
              "cost": {
                "type": "object"
              },
              "effects": {
                "type": "object"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op",
              "opId",
              "techId",
              "fieldPath",
              "deltaNumber"
            ],
            "properties": {
              "op": {
                "const": "tweakTech"
              },
              "opId": {
                "type": "string",
                "minLength": 1
              },
              "techId": {
                "type": "string",
                "minLength": 1
              },
              "fieldPath": {
                "type": "string",
                "minLength": 1
              },
              "deltaNumber": {
                "type": "number"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op",
              "opId",
              "eventId",
              "type",
              "params",
              "durationTicks"
            ],
            "properties": {
              "op": {
                "const": "addWorldEvent"
              },
              "opId": {
                "type": "string",
                "minLength": 1
              },
              "eventId": {
                "type": "string",
                "minLength": 1
              },
              "type": {
                "type": "string",
                "minLength": 1
              },
              "params": {
                "type": "object"
              },
              "durationTicks": {
                "type": "integer"
              },
              "severity": {
                "type": "string",
                "enum": ["minor", "major", "epic"]
              },
              "effects": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "type",
                    "domain",
                    "modifier",
                    "durationTicks"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "domain_modifier"
                    },
                    "domain": {
                      "type": "string",
                      "minLength": 1
                    },
                    "modifier": {
                      "type": "number"
                    },
                    "durationTicks": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op",
              "opId",
              "beatId",
              "text",
              "durationTicks"
            ],
            "properties": {
              "op": {
                "const": "addStoryBeat"
              },
              "opId": {
                "type": "string",
                "minLength": 1
              },
              "beatId": {
                "type": "string",
                "minLength": 1
              },
              "text": {
                "type": "string",
                "minLength": 1
              },
              "durationTicks": {
                "type": "integer"
              },
              "severity": {
                "type": "string",
                "enum": [
                  "minor",
                  "major",
                  "epic"
                ]
              },
              "effects": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "type",
                    "domain",
                    "modifier",
                    "durationTicks"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "domain_modifier"
                    },
                    "domain": {
                      "type": "string",
                      "minLength": 1
                    },
                    "modifier": {
                      "type": "number"
                    },
                    "durationTicks": {
                      "type": "integer"
                    }
                  }
                }
              },
              "causalChain": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "type",
                  "condition",
                  "followUpBeat",
                  "windowTicks",
                  "maxTriggers"
                ],
                "properties": {
                  "type": {
                    "type": "string",
                    "const": "causal_chain"
                  },
                  "condition": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "metric",
                      "operator",
                      "threshold"
                    ],
                    "properties": {
                      "metric": {
                        "type": "string",
                        "enum": [
                          "food_reserves_pct",
                          "morale_avg",
                          "population",
                          "economy_output"
                        ]
                      },
                      "operator": {
                        "type": "string",
                        "enum": [
                          "lt",
                          "gt",
                          "eq"
                        ]
                      },
                      "threshold": {
                        "type": "number"
                      }
                    }
                  },
                  "followUpBeat": {
                    "type": "object",
                    "additionalProperties": false,
                    "required": [
                      "beatId",
                      "text",
                      "durationTicks"
                    ],
                    "properties": {
                      "beatId": {
                        "type": "string",
                        "minLength": 1
                      },
                      "text": {
                        "type": "string",
                        "minLength": 1
                      },
                      "durationTicks": {
                        "type": "integer"
                      },
                      "severity": {
                        "type": "string",
                        "enum": [
                          "minor",
                          "major",
                          "epic"
                        ]
                      },
                      "effects": {
                        "type": "array",
                        "items": {
                          "type": "object",
                          "additionalProperties": false,
                          "required": [
                            "type",
                            "domain",
                            "modifier",
                            "durationTicks"
                          ],
                          "properties": {
                            "type": {
                              "type": "string",
                              "const": "domain_modifier"
                            },
                            "domain": {
                              "type": "string",
                              "minLength": 1
                            },
                            "modifier": {
                              "type": "number"
                            },
                            "durationTicks": {
                              "type": "integer"
                            }
                          }
                        }
                      }
                    }
                  },
                  "windowTicks": {
                    "type": "integer",
                    "minimum": 10,
                    "maximum": 100
                  },
                  "maxTriggers": {
                    "type": "integer",
                    "const": 1
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op",
              "opId",
              "colonyId",
              "directive",
              "durationTicks"
            ],
            "properties": {
              "op": {
                "const": "setColonyDirective"
              },
              "opId": {
                "type": "string",
                "minLength": 1
              },
              "colonyId": {
                "type": "integer",
                "minimum": 0
              },
              "directive": {
                "type": "string",
                "minLength": 1
              },
              "durationTicks": {
                "type": "integer"
              },
              "biases": {
                "type": "array",
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "type",
                    "goalCategory",
                    "weight"
                  ],
                  "properties": {
                    "type": {
                      "type": "string",
                      "const": "goal_bias"
                    },
                    "goalCategory": {
                      "type": "string",
                      "minLength": 1
                    },
                    "weight": {
                      "type": "number"
                    },
                    "durationTicks": {
                      "type": "integer"
                    }
                  }
                }
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op",
              "opId",
              "attackerFactionId",
              "defenderFactionId"
            ],
            "properties": {
              "op": {
                "const": "declareWar"
              },
              "opId": {
                "type": "string",
                "minLength": 1
              },
              "attackerFactionId": {
                "type": "integer",
                "minimum": 0
              },
              "defenderFactionId": {
                "type": "integer",
                "minimum": 0
              },
              "reason": {
                "type": "string"
              }
            }
          },
          {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "op",
              "opId",
              "proposerFactionId",
              "receiverFactionId",
              "treatyKind"
            ],
            "properties": {
              "op": {
                "const": "proposeTreaty"
              },
              "opId": {
                "type": "string",
                "minLength": 1
              },
              "proposerFactionId": {
                "type": "integer",
                "minimum": 0
              },
              "receiverFactionId": {
                "type": "integer",
                "minimum": 0
              },
              "treatyKind": {
                "type": "string",
                "enum": [
                  "ceasefire",
                  "peace_talks"
                ]
              },
              "note": {
                "type": "string"
              }
            }
          }
        ]
      }
    },
    "explain": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
